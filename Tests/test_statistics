import unittest
from unittest.mock import Mock, patch, MagicMock

import sys
import os
sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '..')))

# Mock discord before importing the cog
sys.modules['discord'] = MagicMock()

from Cogs.stats import StatsCog

class TestStatsCog(unittest.TestCase):
    """Unit tests for the data processing logic in stats.py"""

    def setUp(self):
        """Set up a mock bot and the StatsCog instance."""
        self.mock_bot = Mock()
        self.stats_cog = StatsCog(self.mock_bot)

        # --- Mock Game Data ---
        self.mock_player_id = 123
        self.mock_player_name = "TestPlayer"

        # A classic game where the player was incorrectly logged as Vigilante (old data)
        self.old_classic_game = {
            "game_summary": {"game_type": "classic", "winning_faction": "Town"},
            "player_data": [{
                "player_id": self.mock_player_id,
                "player_name": self.mock_player_name,
                "alignment": "Vigilante", # Incorrect data for classic mode
                "is_winner": True
            }]
        }
        # A proper classic game where the player was Town and won
        self.good_classic_game_win = {
            "game_summary": {"game_type": "classic", "winning_faction": "Town"},
            "player_data": [{
                "player_id": self.mock_player_id,
                "player_name": self.mock_player_name,
                "alignment": "Town",
                "is_winner": True
            }]
        }
        # A battle royale game where the player won
        self.br_game_win = {
            "game_summary": {"game_type": "battle_royale", "winning_faction": self.mock_player_name},
            "player_data": [{
                "player_id": self.mock_player_id,
                "player_name": self.mock_player_name,
                "role": "Vigilante",
                "is_winner": True
            }]
        }
        # A game that ended in a draw
        self.draw_game = {
             "game_summary": {"game_type": "classic", "winning_faction": "Draw"},
             "player_data": []
        }
        # A game where Mafia won
        self.mafia_win_game = {
            "game_summary": {"game_type": "classic", "winning_faction": "Mafia"},
            "player_data": []
        }


    def test_normalize_player_alignment_handles_old_data(self):
        """Test that old data (e.g., role as alignment) gets normalized to Town/Mafia."""
        player_data = self.old_classic_game['player_data'][0]
        game_type = self.old_classic_game['game_summary']['game_type']
        
        normalized_alignment = self.stats_cog._normalize_player_alignment(player_data, game_type)
        self.assertEqual(normalized_alignment, "Town")

    def test_win_rate_calculation_with_varied_outcomes(self):
        """Test that win rates are calculated correctly across multiple games."""
        games = [self.good_classic_game_win, self.br_game_win, self.draw_game, self.mafia_win_game]
        win_stats = self.stats_cog._calculate_win_rates(games, 'classic')
        
        self.assertEqual(win_stats['Town']['count'], 1)
        self.assertAlmostEqual(win_stats['Town']['rate'], 25.0)

        self.assertEqual(win_stats['Mafia']['count'], 1)
        self.assertAlmostEqual(win_stats['Mafia']['rate'], 25.0)

        self.assertEqual(win_stats['Draw']['count'], 1)
        self.assertAlmostEqual(win_stats['Draw']['rate'], 25.0)
    
    def test_win_rate_calculation_with_no_games(self):
        """Test that win rate calculation handles an empty list of games gracefully."""
        games = []
        win_stats = self.stats_cog._calculate_win_rates(games, 'classic')
        
        # We expect an empty dictionary back, not a crash from division by zero.
        self.assertEqual(win_stats, {})

    def test_build_player_stats_embed_creates_correct_fields(self):
        """
        Test that the embed builder creates the correct sections for a player
        who has played in both game modes.
        """
        player_games = {
            'classic': [self.good_classic_game_win],
            'battle_royale': [self.br_game_win]
        }
        
        mock_member = Mock()
        mock_member.display_name = self.mock_player_name
        mock_member.display_avatar.url = "http://example.com/avatar.png"
        
        embed = self.stats_cog._build_player_stats_embed(mock_member, player_games)
        
        # The embed should have a description and two fields (one for each mode)
        self.assertIsNotNone(embed.description)
        self.assertEqual(len(embed.fields), 2)
        
        # Check field titles
        field_titles = [field.name for field in embed.fields]
        self.assertIn("Battle Royale Stats", field_titles)
        self.assertIn("Classic Mode Stats", field_titles)

if __name__ == '__main__':
    unittest.main()
